  "author": "GoCodeAlone",
  "capabilities": {
    "buildHooks": [],
    "cliCommands": [
      {
        "description": "Run and inspect database migrations",
        "flags_passthrough": true,
        "name": "db-migrate",
        "subcommands": [
          {
            "description": "Apply all pending migrations",
            "name": "up"
          },
          {
            "description": "Roll back migrations",
            "name": "down"
          },
          {
            "description": "Show migration status",
            "name": "status"
          },
          {
            "description": "Migrate to a specific version",
            "name": "goto"
          },
          {
            "description": "Force-set the recorded migration version",
            "name": "force"
          },
          {
            "description": "Repair a known dirty migration metadata state",
            "name": "repair-dirty"
          },
          {
            "description": "Validate a candidate migration directory against a baseline",
            "name": "validate-upgrade"
          },
          {
            "description": "Static analysis for migration files",
            "name": "lint"
          },
          {
            "description": "Run full-cycle and checkpoint migration tests",
            "name": "test"
          },
          {
            "description": "Ensure a tenant schema exists in the database",
            "name": "tenant-ensure"
          }
        ]
      }
    ],
    "configProvider": false,
    "migrationDrivers": [
      "golang-migrate",
      "goose"
    ],
    "moduleTypes": [
      "database.migrations",
      "database.migration_driver"
    ],
    "stepTypes": [
      "step.migrate_up",
      "step.migrate_down",
      "step.migrate_status",
      "step.migrate_to"
    ],
    "triggerTypes": []
  },
  "category": "data",
  "description": "Database migration plugin for the workflow engine: golang-migrate + goose drivers, pre-deploy runner, wfctl migrate CLI, static lint tool, and tenant-ensure schema setup",
